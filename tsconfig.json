{
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs",
      "verbatimModuleSyntax": false
    }
  },
  "compilerOptions": {
    "outDir": "./dist",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "target": "es2022",
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": false
  },
  "include": [
    "src/**/*.ts",
    "db/**/*.ts"
  ]
}